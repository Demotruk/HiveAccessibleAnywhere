# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Operator's Telegram user ID (numeric). Use /myid command or @userinfobot to find yours.
OPERATOR_TELEGRAM_ID=

# Hive account that receives HBD payments
HIVE_ACCOUNT=

# Comma-separated Hive RPC nodes (optional)
# HIVE_NODES=https://api.hive.blog,https://api.deathwing.me

# Path to giftcard output directory (default: ../scripts/giftcard-output)
# GIFTCARD_OUTPUT_DIR=../scripts/giftcard-output

# Default gift card price in HBD (e.g. 5.000)
GIFT_PRICE_HBD=5.000

# Minutes to wait for payment before expiry (default: 30)
# PAYMENT_TIMEOUT_MINUTES=30

# SQLite database path (default: ./data/bot.db)
# DB_PATH=./data/bot.db

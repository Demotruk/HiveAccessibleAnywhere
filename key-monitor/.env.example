# Required: comma-separated Hive accounts to watch for unexpected operations
WATCH_ACCOUNTS=issuer-account-1,issuer-account-2

# Required: Telegram bot token for sending alerts
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Required: Telegram chat ID to send alerts to (user or group)
TELEGRAM_CHAT_ID=123456789

# Optional: comma-separated Hive API nodes (defaults to public nodes)
# HIVE_NODES=https://api.hive.blog,https://api.deathwing.me,https://hive-api.arcange.eu

# Optional: polling interval in milliseconds (default: 15000)
# POLL_INTERVAL_MS=15000

# Optional: path to state persistence file (default: ./data/state.json)
# STATE_FILE=./data/state.json

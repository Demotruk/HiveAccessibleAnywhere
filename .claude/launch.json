{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "wallet-dev",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5173", "--host", "127.0.0.1"],
      "port": 5173,
      "cwd": "wallet"
    },
    {
      "name": "wallet-phase2",
      "runtimeExecutable": "node",
      "runtimeArgs": ["node_modules/vite/bin/vite.js", "--port", "5174", "--host", "127.0.0.1"],
      "port": 5174,
      "cwd": "wallet",
      "env": { "PHASE": "2" }
    },
    {
      "name": "docs-preview",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080", "--directory", "docs"],
      "port": 8080
    },
    {
      "name": "bootstrap-test",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8090", "--directory", "wallet/dist"],
      "port": 8090
    },
    {
      "name": "proxy-food",
      "runtimeExecutable": "node",
      "runtimeArgs": ["--import", "tsx", "src/server.ts"],
      "port": 3100,
      "cwd": "proxy",
      "autoPort": false,
      "env": { "COVER_SITE_THEME": "food", "PROXY_INSTANCE_ID": "test-food" }
    }
  ]
}

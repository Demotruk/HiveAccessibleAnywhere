# === Single-Tenant Mode (default) ===

# Required: Hive account that owns claimed account tokens
GIFTCARD_PROVIDER_ACCOUNT=your-hive-account

# Required (single-tenant): provider's active key (WIF)
GIFTCARD_ACTIVE_KEY=5K...

# Required (single-tenant): provider's memo key (WIF)
GIFTCARD_MEMO_KEY=5K...

# Required: feed/discovery service account name
HAA_SERVICE_ACCOUNT=haa-service

# Required: HP delegation amount for new accounts (e.g. '30000.000000 VESTS')
GIFTCARD_DELEGATION_VESTS=30000.000000 VESTS

# === Multi-Tenant Mode ===
# Set both to enable multi-tenant (providers delegate active authority to service account)

# GIFTCARD_SERVICE_ACCOUNT=your-service-account
# GIFTCARD_SERVICE_ACTIVE_KEY=5K...
# GIFTCARD_SERVICE_MEMO_KEY=5K...
# GIFTCARD_ALLOWED_PROVIDERS=issuer1,issuer2

# === Dashboard API ===

# JWT secret for dashboard session tokens (required for dashboard endpoints)
# GIFTCARD_JWT_SECRET=your-secret-here

# === Optional ===

# GIFTCARD_ADMIN_ACCOUNTS=admin1,admin2
# GIFTCARD_PREAPPROVED_ISSUERS=user1,user2
# GIFTCARD_NOTIFY_ACCOUNT=notify-account
# GIFTCARD_NOTIFY_ACTIVE_KEY=5K...
# GIFTCARD_SERVICE_URL=https://your-service.example.com
# GIFTCARD_INVITE_BASE_URL=https://hiveinvite.com
# GIFTCARD_POSTING_KEY=5K...
# GIFTCARD_DB_PATH=/data/tokens.db
# PORT=3200
# COVER_SITE_THEME=tech
# HIVE_NODES=https://api.hive.blog,https://api.deathwing.me,https://hive-api.arcange.eu
